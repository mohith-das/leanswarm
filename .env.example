LEANSWARM_DRY_RUN=true
LEANSWARM_CACHE_DIR=.leanswarm/cache
LEANSWARM_LOG_DIR=.leanswarm/logs
LEANSWARM_SEMANTIC_STORE_PATH=.leanswarm/cache/semantic_memory.sqlite3
LEANSWARM_SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
LEANSWARM_SEMANTIC_MAX_ENTRIES_PER_AGENT=256
LEANSWARM_ALLOW_EMBEDDING_DOWNLOADS=false
LEANSWARM_MAX_CONCURRENCY=4
LEANSWARM_RETRY_ATTEMPTS=3
LEANSWARM_FLAGSHIP_MODEL=gpt-4.1
LEANSWARM_STANDARD_MODEL=gpt-4.1-mini
LEANSWARM_CHEAP_MODEL=gpt-4.1-nano
LEANSWARM_API_HOST=127.0.0.1
LEANSWARM_API_PORT=8000

# --- Live mode ---------------------------------------------------------
# Dry-run is the default. To use real models set:
#   LEANSWARM_DRY_RUN=false   (or pass --live on the CLI)
# and configure ONE of the provider blocks below, then set the tier models.

# OpenAI:      OPENAI_API_KEY=...        models: gpt-4.1, gpt-4.1-mini, ...
# Anthropic:   ANTHROPIC_API_KEY=...     models: anthropic/claude-sonnet-5, ...
# DeepSeek:    DEEPSEEK_API_KEY=...      models: deepseek/deepseek-chat, deepseek/deepseek-reasoner
# Zhipu GLM:   ZHIPUAI_API_KEY=...       models: zhipuai/glm-4.5, ...
# Groq:        GROQ_API_KEY=...          models: groq/llama-3.3-70b-versatile, ...
# OpenRouter:  OPENROUTER_API_KEY=...    models: openrouter/<any>, ...
# Ollama:      (no key)                  models: ollama/llama3.1, ...
#
# Any OpenAI-compatible endpoint (MiniMax, GLM, vLLM, custom gateways):
#   LEANSWARM_API_BASE=https://api.minimax.io/v1
#   LEANSWARM_API_KEY=...
#   LEANSWARM_FLAGSHIP_MODEL=openai/MiniMax-M2   # openai/<served-model-name>

# Example DeepSeek setup:
# LEANSWARM_DRY_RUN=false
# DEEPSEEK_API_KEY=sk-...
# LEANSWARM_FLAGSHIP_MODEL=deepseek/deepseek-chat
# LEANSWARM_STANDARD_MODEL=deepseek/deepseek-chat
# LEANSWARM_CHEAP_MODEL=deepseek/deepseek-chat

# --- SMTP for password-reset emails (optional) -------------------------
# LEANSWARM_SMTP_HOST=smtp.purelymail.com
# LEANSWARM_SMTP_PORT=465
# LEANSWARM_SMTP_USERNAME=you@purelymail.com
# LEANSWARM_SMTP_PASSWORD=your_app_password
# LEANSWARM_FROM_EMAIL=noreply@yourdomain.com
