LEANSWARM_DRY_RUN=true
LEANSWARM_CACHE_DIR=.leanswarm/cache
LEANSWARM_LOG_DIR=.leanswarm/logs
LEANSWARM_SEMANTIC_STORE_PATH=.leanswarm/cache/semantic_memory.sqlite3
LEANSWARM_SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
LEANSWARM_SEMANTIC_MAX_ENTRIES_PER_AGENT=256
LEANSWARM_ALLOW_EMBEDDING_DOWNLOADS=false
LEANSWARM_MAX_CONCURRENCY=4
LEANSWARM_RETRY_ATTEMPTS=3
LEANSWARM_FLAGSHIP_MODEL=gpt-4.1
LEANSWARM_STANDARD_MODEL=gpt-4.1-mini
LEANSWARM_CHEAP_MODEL=gpt-4.1-nano
LEANSWARM_API_HOST=127.0.0.1
LEANSWARM_API_PORT=8000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
